# Frontend build, for Vercel/Netlify/Cloudflare Pages.
VITE_API_BASE=https://cicadafreedom.com/api

# API server, for Render/Railway/Fly/VPS.
PORT=8787
HOST=0.0.0.0
ALLOWED_ORIGINS=https://cicadafreedom.com,https://www.cicadafreedom.com

# User auth. Replace this before public launch.
VERIFICATION_CODE=replace-with-private-code

# Admin auth. Replace every value before public launch.
ADMIN_EMAIL=admin@cicadafreedom.com
ADMIN_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN_TTL_MS=86400000
